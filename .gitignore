# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and care about the specific version of Python.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or experience
#   issues with locking, it might be preferred to ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   However, in case of collaboration, it might be preferred to ignore it.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
.pdm-plugins/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
